<form method="post"
      action="{{ path('app_client_delete', {'id': client.id}) }}"
      onsubmit="return confirm('Supprimer ce client ?');">

    <input type="hidden"
           name="_token"
           value="{{ csrf_token('delete' ~ client.id) }}">

    <button class="text-gray-400 hover:text-red-600 transition"
            title="Supprimer">
        🗑️
    </button>
</form>