{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto p-8 relative">

<div class="absolute top-8 right-8">
        <form method="post"
              action="{{ path('app_profile_delete') }}"
              onsubmit="return confirm('Voulez-vous vraiment supprimer votre compte ?');">

            <input type="hidden"
                   name="_token"
                   value="{{ csrf_token('delete_account') }}">

            <button type="submit"
                    class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium shadow-sm">
                Supprimer mon compte
            </button>
        </form>
    </div>

    <h1 class="px-4 text-2xl font-bold text-gray-900 mb-6">Mon Profil</h1>

    {% for message in app.flashes('success') %}
        <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-xl text-sm">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="mb-4 p-4 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm">{{ message }}</div>
    {% endfor %}

    <div class="bg-white rounded-2xl shadow-sm ring-1 ring-black/5 p-8">
        {{ form_start(profileForm, {'attr': {'class': 'space-y-5'}}) }}

            {# Prénom / Nom #}
            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(profileForm.firstName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.firstName, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition', 'placeholder': 'Prénom'}}) }}
                    {{ form_errors(profileForm.firstName) }}
                </div>
                <div>
                    {{ form_label(profileForm.lastName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.lastName, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition', 'placeholder': 'Nom'}}) }}
                    {{ form_errors(profileForm.lastName) }}
                </div>
            </div>

            {# Email #}
            <div>
                {{ form_label(profileForm.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(profileForm.email, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition', 'placeholder': 'contact@entreprise.fr'}}) }}
                {{ form_errors(profileForm.email) }}
            </div>

            {# Raison Sociale #}
            <div>
                {{ form_label(profileForm.companyName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(profileForm.companyName, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition'}}) }}
                <p class="text-xs text-gray-400 mt-1">Le nom de votre entreprise qui apparaîtra sur vos factures.</p>
                {{ form_errors(profileForm.companyName) }}
            </div>

            {# Adresse #}
            <div>
                {{ form_label(profileForm.adress, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(profileForm.adress, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition', 'placeholder': '12 rue de la Paix'}}) }}
                {{ form_errors(profileForm.adress) }}
            </div>

            {# Code Postal / Ville #}
            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(profileForm.postalCode, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.postalCode, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition', 'placeholder': '75000'}}) }}
                    {{ form_errors(profileForm.postalCode) }}
                </div>
                <div>
                    {{ form_label(profileForm.town, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.town, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition', 'placeholder': 'Paris'}}) }}
                    {{ form_errors(profileForm.town) }}
                </div>
            </div>

            {# SIRET / SIREN #}
            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(profileForm.siret, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.siret, {'attr': {
                        'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500 transition',
                        'placeholder': '12345678900010',
                        'maxlength': '14',
                        'id': 'siret-field'
                    }}) }}
                    <span id="siret-hint" class="text-xs text-gray-400 mt-1"></span>
                    {{ form_errors(profileForm.siret) }}
                </div>
                <div>
                    {{ form_label(profileForm.siren, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.siren, {'attr': {
                        'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500 transition',
                        'placeholder': '123456789',
                        'maxlength': '9',
                        'id': 'siren-field'
                    }}) }}
                    <span class="text-xs text-gray-400 mt-1">Calculé automatiquement depuis le SIRET</span>
                    {{ form_errors(profileForm.siren) }}
                </div>
            </div>

            {# IBAN #}
            <div>
                {{ form_label(profileForm.iban, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(profileForm.iban, {'attr': {
                    'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500 transition',
                    'placeholder': 'FR76 1234 5678 9012 3456 7890 123',
                    'id': 'iban-field'
                }}) }}
                <span id="iban-hint" class="text-xs text-gray-400 mt-1">Compte bancaire qui recevra les virements de vos clients.</span>
                {{ form_errors(profileForm.iban) }}
            </div>

            {# Téléphones #}
            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(profileForm.phoneFixed, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.phoneFixed, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition', 'placeholder': '01 23 45 67 89'}}) }}
                    {{ form_errors(profileForm.phoneFixed) }}
                </div>
                <div>
                    {{ form_label(profileForm.phoneMobile, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                   {{ form_widget(profileForm.phoneMobile, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition'
                    }}) }}
                    {{ form_errors(profileForm.phoneMobile) }}
                </div>
            </div>

            {# Type de structure #}

           <div>
            {{ form_label(profileForm.companyType, null, {
            'label_attr': {
            'class': 'block text-sm font-medium text-gray-700 mb-1'
            }
            }) }}

            {{ form_widget(profileForm.companyType, {
            'attr': {
            'id': 'company-type',
            'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition'
            }
            }) }}

            <p class="text-xs text-gray-400 mt-1">
            Sélectionnez votre structure pour pré-remplir vos CGV.
            </p>

            {{ form_errors(profileForm.companyType) }}
        </div>

            {# CGV #}
            <div>
                {{ form_widget(profileForm.cgv, {
                'attr': {
                'id': 'cgv-field',
                'rows': '15',
                'class': 'w-full px-3 py-2.5 border border-gray-200 rounded-lg'
                }
            }) }}
            </div>

            {# Submit #}
            <button type="submit" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-xl transition focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                Enregistrer les modifications
            </button>

        {{ form_end(profileForm) }}
            </div>

            <hr class="my-8">

           
           
    </div>
</div>

<script>

document.addEventListener('DOMContentLoaded', () => {

    const companyType = document.getElementById('company-type');

    const cgvField = document.getElementById('cgv-field');

    companyType.addEventListener('change', async () => {

        const type = companyType.value;

        if (!type) {
            return;
        }

        /*
        Empêche l'écrasement accidentel
        */

        if (cgvField.value.trim() !== '') {

            const confirmReplace = confirm(
                "Voulez-vous remplacer les CGV actuelles ?"
            );

            if (!confirmReplace) {
                return;
            }
        }

        try {

            const response = await fetch(
                `/cgv/template/${type}`
            );

            const data = await response.json();

            if (data.success) {

                cgvField.value = data.content;
            }

        } catch (error) {

            console.error(error);

            alert('Erreur lors du chargement des CGV');
        }

    });

});

</script>


{% endblock %}