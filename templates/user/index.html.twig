{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block body %}
    <h1>User index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>First_name</th>
                <th>Last_name</th>
                <th>Password</th>
                <th>Company_name</th>
                <th>Adress</th>
                <th>PostalCode</th>
                <th>Town</th>
                <th>Iban</th>
                <th>Siret</th>
                <th>Siren</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.firstName }}</td>
                <td>{{ user.lastName }}</td>
                <td>{{ user.password }}</td>
                <td>{{ user.companyName }}</td>
                <td>{{ user.adress }}</td>
                <td>{{ user.postalCode }}</td>
                <td>{{ user.town }}</td>
                <td>{{ user.iban }}</td>
                <td>{{ user.siret }}</td>
                <td>{{ user.siren }}</td>
                <td>
                    <a href="{{ path('app_user_show', {'id': user.id}) }}">show</a>
                    <a href="{{ path('app_user_edit', {'id': user.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="12">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_user_new') }}">Create new</a>
{% endblock %}
