<aside class="w-64 bg-white border-r border-gray-200 flex flex-col h-screen fixed top-0 left-0" {{attributes}}>
    <div class="p-6">
        <div class="flex items-center gap-2 text-blue-600 font-bold text-xl">
            <span class="bg-blue-600 text-white px-2 py-0.5 rounded">$</span> FacturSaaS
        </div>
    </div>

    <nav class="flex-1 px-4 space-y-2 overflow-y-auto">
        <a href="{{ path('app_dashboard') }}" class="flex items-center gap-3 text-gray-600 hover:bg-blue-50 px-4 py-3 rounded-xl font-medium">
            <span>📊</span> Dashboard
        </a>
        <a href="{{ path('app_invoice_index') }}" class="flex items-center gap-3 text-gray-600 hover:bg-blue-50 px-4 py-3 rounded-xl font-medium">
            <span>📄</span> Factures
        </a>
        <a href="{{ path('app_client_index') }}" class="flex items-center gap-3 text-gray-600 hover:bg-blue-50 px-4 py-3 rounded-xl font-medium">
            <span>👥</span> Clients
        </a>
        <a href="{{ path('app_product_index') }}" class="flex items-center gap-3 text-gray-600 hover:bg-blue-50 px-4 py-3 rounded-xl font-medium">
            <span>📦</span> Produits
        </a>
        <a href="{{ path('app_profile') }}" class="flex items-center gap-3 text-gray-600 hover:bg-blue-50 px-4 py-3 rounded-xl font-medium">
            <span>⚙️</span> Profil
        </a>
    </nav>

    {# ✅ Un seul bloc utilisateur dynamique #}
    <div class="p-4 border-t border-gray-100 bg-white">
        <div class="flex items-center gap-3 mb-4">
            {% if app.user %}
                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center font-bold text-blue-600 flex-shrink-0">
                    {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                </div>
                <div class="overflow-hidden">
                    <p class="text-sm font-bold text-gray-800 truncate">{{ app.user.companyName }}</p>
                    <p class="text-xs text-gray-500 truncate">{{ app.user.email }}</p>
                </div>
            {% else %}
                <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center font-bold text-gray-400 flex-shrink-0">
                    ?
                </div>
                <div class="overflow-hidden">
                    <p class="text-sm text-gray-400">Non connecté</p>
                </div>
            {% endif %}
        </div>

        {% if app.user %}
        <a href="{{ path('app_logout') }}"
          class="text-red-500 text-sm font-semibold flex items-center gap-2 hover:bg-red-50 w-full px-4 py-2 rounded mb-10">
            <span>🚪</span> Se déconnecter
        </a>
        {% endif %}
    </div>
</aside>