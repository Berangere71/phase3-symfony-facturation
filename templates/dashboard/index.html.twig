{% extends 'base.html.twig' %}

{% block body %}
    <div class="max-w-6xl mx-auto">
        <h1 class="text-2xl font-bold text-gray-800 mb-8">Dashboard</h1>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
            {% for item in stats %}
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                    <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4 
                        {{ item.color == 'green' ? 'bg-green-100 text-green-600' : 
                           item.color == 'orange' ? 'bg-orange-100 text-orange-600' :
                           item.color == 'blue' ? 'bg-blue-100 text-blue-600' : 'bg-purple-100 text-purple-600' }}">
                        {{ item.icon }}
                    </div>
                    <p class="text-gray-500 text-sm mb-1">{{ item.label }}</p>
                    <p class="text-2xl font-bold text-gray-800">{{ item.value }}</p>
                </div>
            {% endfor %}
        </div>

       <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 mb-8">
    <div class="flex justify-between items-center mb-10">
        <h2 class="font-bold text-gray-800">Chiffre d'affaires mensuel (Factures payées)</h2>
        <div class="text-sm text-gray-400 border rounded-lg px-3 py-1 flex items-center gap-2">
            2023 <span>▼</span>
        </div>
    </div>
    
    <div class="flex">
        <div class="flex flex-col justify-between text-right pr-4 text-xs text-gray-400 pb-6 h-64 font-medium">
            <span>3 000 €</span>
            <span>2 500 €</span>
            <span>2 000 €</span>
            <span>1 500 €</span>
            <span>1 000 €</span>
            <span>500 €</span>
            <span><class="mt-auto">0 €</span>
        </div>

        <div class="flex-1 h-64 relative border-b border-gray-100 flex items-end justify-between px-2">
            <div class="absolute inset-0 flex flex-col justify-between pointer-events-none">
                <div class="border-t border-gray-50 w-full h-0"></div>
                <div class="border-t border-gray-50 w-full h-0"></div>
                <div class="border-t border-gray-50 w-full h-0"></div>
                <div class="w-full h-0"></div> </div>

            {% set months = ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin', 'Juil', 'Aoû', 'Sep', 'Oct', 'Nov', 'Déc'] %}
            {% for month in months %}
                <div class="relative flex flex-col items-center group w-full">
                    {# On simule une valeur haute pour Mars comme sur ton image #}
                    {% if month == 'Mar' %}
                        <div class="w-8 bg-blue-500 rounded-t-md transition-all duration-500 hover:bg-blue-600 cursor-pointer" style="height: 192px;">
                            <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-gray-800 text-white text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition shadow-lg">
                                2 250 €
                            </div>
                        </div>
                    {% else %}
                        {# Barres vides ou très basses pour les autres mois #}
                        <div class="w-8 bg-gray-100 rounded-t-md h-4 hover:bg-gray-200 transition-all cursor-pointer"></div>
                    {% endif %}
                    
                    <span class="absolute -bottom-7 text-[11px] text-gray-400 font-medium">{{ month }}</span>
                </div>
            {% endfor %}
        </div>
    </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-20 mb-10">
            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 flex justify-between items-center group cursor-pointer hover:bg-blue-100 transition">
                <div>
                    <p class="text-gray-700 font-bold">Créer une facture</p>
                    <p class="text-gray-500 text-xs">Nouvelle prestation</p>
                </div>
                <span class="text-blue-600 group-hover:translate-x-1 transition">→</span>
            </div>
            
            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 flex justify-between items-center group cursor-pointer hover:bg-blue-100 transition">
                <div>
                    <p class="text-gray-700 font-bold">Ajouter un client</p>
                    <p class="text-gray-500 text-xs">Gérer le répertoire</p>
                </div>
                <span class="text-gray-400 group-hover:translate-x-1 transition">→</span>
            </div>

            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 flex justify-between items-center group cursor-pointer hover:bg-blue-100 transition">
                <div>
                    <p class="text-gray-700 font-bold">Créer un produit</p>
                    <p class="text-gray-500 text-xs">Enrichir le catalogue</p>
                </div>
                <span class="text-gray-400 group-hover:translate-x-1 transition">→</span>
            </div>
            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 flex justify-between items-center group cursor-pointer hover:bg-blue-100 transition">
                <div>
                    <p class="text-gray-700 font-bold">Relancer tous les clients</p>
                    <p class="text-gray-500 text-xs">Envoyer un mail à tout les clients en retard de paiement</p>
                </div>
                <span class="text-gray-400 group-hover:translate-x-1 transition">→</span>
            </div>
        </div>
    </div>
{% endblock %}